generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int        @id @default(autoincrement())
  email            String     @unique
  username         String     @unique
  password         String
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime   @default(now())
  rooms            RoomMember[]
  bio              String?    @default("Collaborative developer")
  tagline          String?    @default("Building things together")
  avatar           String?    @default("")
}

model Room {
  id                 String   @id @default(cuid())
  name               String
  language           String   @default("javascript")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  ownerId            Int
  members            RoomMember[]
  files              File[]
  snapshots          Snapshot[]
  messages           Message[]
  whiteboardElements String?  @default("[]")
}

model File {
  id        String   @id @default(cuid())
  name      String
  language  String   @default("javascript")
  content   String   @default("")
  order     Int      @default(0)
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomMember {
  userId Int
  roomId String
  role   String @default("editor")
  user   User   @relation(fields: [userId], references: [id])
  room   Room   @relation(fields: [roomId], references: [id])

  @@id([userId, roomId])
}

model Snapshot {
  id      Int      @id @default(autoincrement())
  roomId  String
  code    String
  savedAt DateTime @default(now())
  room    Room     @relation(fields: [roomId], references: [id])
}

model Message {
  id        String   @id @default(cuid())
  roomId    String
  username  String
  avatar    String?
  text      String
  timestamp DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
}